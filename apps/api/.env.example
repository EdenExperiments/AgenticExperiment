# App Postgres (your app data, not Supabase)
DATABASE_URL=postgres://rpgtracker:rpgtracker@localhost:5432/rpgtracker?sslmode=disable

# Supabase — same project URL as NEXT_PUBLIC_SUPABASE_URL on the frontend
SUPABASE_URL=https://your-project.supabase.co
# Same publishable key as NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY on the frontend
SUPABASE_PUBLISHABLE_KEY=sb_publishable_xxx

# AES-256-GCM master key (exactly 32 chars)
MASTER_KEY=32-characters-exactly-for-aes-gcm-master-key!

# Optional
PORT=8080
