# Required: PostgreSQL connection string
DATABASE_URL=postgres://rpgtracker:rpgtracker@localhost:5432/rpgtracker?sslmode=disable

# Required: Supabase (same names as apps/api)
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_PUBLISHABLE_KEY=sb_publishable_xxx

# Required: 32-byte hex master key used for AES-256-GCM encryption
MASTER_KEY=your-32-byte-hex-master-key-here-replace

# Optional: HTTP server port (default: 8080)
PORT=8080
