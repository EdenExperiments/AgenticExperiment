# Required: PostgreSQL connection string
DATABASE_URL=postgres://rpgtracker:rpgtracker@localhost:5432/rpgtracker?sslmode=disable

# Required: Supabase project URL (from your Supabase project settings)
SUPABASE_PROJECT_URL=https://your-project.supabase.co

# Required: Supabase anonymous/public key (from your Supabase project settings > API)
SUPABASE_ANON_KEY=your-anon-key

# Required: 32-byte hex master key used for AES-256-GCM encryption
MASTER_KEY=your-32-byte-hex-master-key-here-replace

# Optional: HTTP server port (default: 8080)
PORT=8080
