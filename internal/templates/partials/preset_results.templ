package partials

import "github.com/meden/rpgtracker/internal/skills"

// PresetResults renders the grouped results list for the preset browse screen.
// Used for HTMX partial swaps (search + category filter) and initial page render.
// filter is used to determine initial open state: sections start open when a filter is active.
templ PresetResults(cats []skills.CategoryWithPresets, filter skills.PresetFilter) {
	if len(cats) == 0 {
		<div class="py-12 text-center text-gray-500 text-sm">No skills match your search.</div>
	} else {
		for _, cat := range cats {
			<div
				class="mb-2"
				x-data={ "{ open: " + openState(filter) + " }" }
			>
				<button
					type="button"
					class="w-full flex items-center justify-between text-gray-500 text-xs font-semibold uppercase tracking-widest px-1 py-2 min-h-[44px] hover:text-gray-300 transition-colors"
					@click="open = !open"
				>
					<span>{ cat.Emoji } { cat.Name }</span>
					<span x-show="!open" class="text-gray-600 text-sm">▶</span>
					<span x-show="open" class="text-gray-600 text-sm">▼</span>
				</button>
				<div x-show="open">
					for _, p := range cat.Presets {
						<a
							href={ templ.URL("/skills/new/from-preset/" + p.ID.String()) }
							class="flex items-center justify-between bg-gray-800 rounded-lg px-4 py-3 mb-1 hover:bg-gray-700 transition-colors min-h-[44px]"
						>
							<div>
								<div class="text-gray-100 text-sm font-medium">{ p.Name }</div>
								<div class="text-gray-500 text-xs mt-0.5">{ p.Description }</div>
							</div>
							<span class="text-indigo-400 text-lg ml-3">›</span>
						</a>
					}
				</div>
			</div>
		}
	}
}

// openState returns the Alpine.js boolean string for x-data based on whether a filter is active.
// When a filter is active, all returned sections start open (they matched the search).
// When no filter is active (first load), all sections start collapsed.
func openState(filter skills.PresetFilter) string {
	if filter.Query != "" || filter.Category != "" {
		return "true"
	}
	return "false"
}
