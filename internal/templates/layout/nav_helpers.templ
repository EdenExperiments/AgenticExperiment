package layout

const dashboardIcon = `<svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 12l2-2m0 0l7-7 7 7M5 10v10a1 1 0 001 1h3m10-11l2 2m-2-2v10a1 1 0 01-1 1h-3m-6 0a1 1 0 001-1v-4a1 1 0 011-1h2a1 1 0 011 1v4a1 1 0 001 1m-6 0h6"/></svg>`

const skillsIcon = `<svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 10V3L4 14h7v7l9-11h-7z"/></svg>`

const nutriIcon = `<svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 3s1 9 8 12M5 3c0 0 9 1 12 8M5 3l14 14"/></svg>`

const accountIcon = `<svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M16 7a4 4 0 11-8 0 4 4 0 018 0zM12 14a7 7 0 00-7 7h14a7 7 0 00-7-7z"/></svg>`

func navItemClass(activePage, thisPage string) string {
	base := "flex flex-col items-center justify-center px-3 py-2 "
	if activePage == thisPage {
		return base + "text-indigo-400 font-semibold"
	}
	return base + "text-gray-400"
}

templ NavItem(href, label, icon, activePage, thisPage string) {
	<a
		href={ templ.URL(href) }
		hx-get={ href }
		hx-target="#main-content"
		hx-push-url="true"
		class={ navItemClass(activePage, thisPage) }
	>
		@templ.Raw(icon)
		<span class="text-xs mt-1">{ label }</span>
	</a>
}
