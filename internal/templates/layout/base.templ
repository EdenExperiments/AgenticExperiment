package layout

templ Base(title string) {
	<!DOCTYPE html>
	<html lang="en">
		<head>
			<meta charset="UTF-8"/>
			<meta name="viewport" content="width=device-width, initial-scale=1"/>
			<title>{ title }</title>
			<script src="https://unpkg.com/htmx.org@2.0.3" integrity="sha384-0895/pl5ih6n080DSAztEDA07Rd0fy6TSIe5kvL34+GITSeILRFfMF/4WMmxhGsy" crossorigin="anonymous"></script>
			<script src="https://cdn.tailwindcss.com"></script>
		</head>
		<body class="bg-gray-950 text-gray-100 min-h-screen">
			{ children... }
		</body>
	</html>
}
