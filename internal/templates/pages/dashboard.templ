package pages

import "github.com/meden/rpgtracker/internal/templates/layout"

// DashboardContent renders the inner dashboard content fragment (for HTMX swaps).
templ DashboardContent() {
	<div class="max-w-2xl mx-auto py-8">
		<h1 class="text-3xl font-bold text-gray-100">Dashboard</h1>
		<p class="mt-2 text-gray-400">LifeQuest — Skills coming in Phase 2</p>
	</div>
}

// Dashboard renders the full page (for direct browser navigation).
templ Dashboard() {
	@layout.Shell("dashboard") {
		@DashboardContent()
	}
}
