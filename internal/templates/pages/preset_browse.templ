package pages

import (
	"github.com/meden/rpgtracker/internal/skills"
	"github.com/meden/rpgtracker/internal/templates/layout"
	"github.com/meden/rpgtracker/internal/templates/partials"
)

// PresetBrowseContent renders the browse UI fragment (used for HTMX nav swaps and as inner content for full page).
templ PresetBrowseContent(allCats []skills.Category, cats []skills.CategoryWithPresets, filter skills.PresetFilter) {
	<div class="max-w-lg mx-auto py-4 px-4">
		<h1 class="text-lg font-semibold text-gray-100 mb-4">Choose a Skill</h1>

		<!-- Search bar with inline clear button (Alpine x-model drives x-show on × button) -->
		<div class="relative mb-3" x-data={ "{ query: '" + filter.Query + "' }" }>
			<input
				type="search"
				name="q"
				value={ filter.Query }
				placeholder="Search skills…"
				class="w-full bg-gray-800 border border-gray-700 rounded-lg px-4 py-2.5 pl-10 pr-8 text-gray-100 text-sm placeholder-gray-500 focus:outline-none focus:border-indigo-500"
				hx-get="/skills/new"
				hx-trigger="input changed delay:300ms"
				hx-target="#preset-results"
				hx-include="[name='category']"
				x-model="query"
				x-ref="searchInput"
			/>
			<span class="absolute left-3 top-2.5 text-gray-500 text-sm">🔍</span>
			<button
				type="button"
				class="absolute right-2 top-1/2 -translate-y-1/2 text-gray-400 hover:text-gray-200 transition-colors p-1"
				x-show="query.length > 0"
				@click="query = ''; $refs.searchInput.value = ''; $refs.searchInput.dispatchEvent(new Event('input'))"
				aria-label="Clear search"
			>✕</button>
		</div>

		<!--
			Category chips: scrollbar hidden on all sizes; desktop gets fade+arrow affordance instead.
			Alpine scope tracks atStart/atEnd to show/hide arrows and gradients.
			@scroll.passive lets the browser continue scrolling without waiting for the JS handler (60fps).
			pointer-events-none on fade overlays keeps chips clickable through the gradient.
		-->
		<div
			class="relative mb-4"
			x-data="{
				atStart: true,
				atEnd: false,
				init() { this.$nextTick(() => this.checkScroll()) },
				checkScroll() {
					const el = this.$refs.chipStrip;
					this.atStart = el.scrollLeft <= 0;
					this.atEnd = el.scrollLeft >= el.scrollWidth - el.clientWidth - 1;
				}
			}"
		>
			<!-- Left fade + arrow (md+ only, hidden when at start) -->
			<div class="hidden md:block absolute left-0 top-0 bottom-1 z-10 pointer-events-none">
				<div
					x-show="!atStart"
					class="flex items-center h-full bg-gradient-to-r from-gray-900 via-gray-900/70 to-transparent pr-5 pointer-events-auto"
				>
					<button
						type="button"
						@click="$refs.chipStrip.scrollBy({ left: -180, behavior: 'smooth' })"
						class="text-gray-300 hover:text-gray-100 transition-colors text-lg leading-none"
						aria-label="Scroll categories left"
					>‹</button>
				</div>
			</div>

			<!-- Scrollable chip strip -->
			<div
				x-ref="chipStrip"
				@scroll.passive="checkScroll()"
				class="flex gap-2 overflow-x-auto pb-1 [&::-webkit-scrollbar]:hidden [-ms-overflow-style:none] [scrollbar-width:none]"
			>
				<button
					name="category"
					value=""
					class={
						"flex-shrink-0 px-3 py-1.5 rounded-full text-xs font-medium transition-colors min-h-[44px] flex items-center",
						templ.KV("bg-indigo-700 text-indigo-100", filter.Category == ""),
						templ.KV("bg-gray-800 text-gray-400 hover:bg-gray-700", filter.Category != ""),
					}
					hx-get="/skills/new"
					hx-target="#preset-results"
					hx-include="[name='q']"
				>All</button>
				for _, cat := range allCats {
					<button
						name="category"
						value={ cat.Slug }
						class={
							"flex-shrink-0 px-3 py-1.5 rounded-full text-xs font-medium transition-colors min-h-[44px] flex items-center",
							templ.KV("bg-indigo-700 text-indigo-100", filter.Category == cat.Slug),
							templ.KV("bg-gray-800 text-gray-400 hover:bg-gray-700", filter.Category != cat.Slug),
						}
						hx-get="/skills/new"
						hx-target="#preset-results"
						hx-include="[name='q']"
					>{ cat.Emoji } { cat.Name }</button>
				}
			</div>

			<!-- Right fade + arrow (md+ only, hidden when at end) -->
			<div class="hidden md:block absolute right-0 top-0 bottom-1 z-10 pointer-events-none">
				<div
					x-show="!atEnd"
					class="flex items-center h-full bg-gradient-to-l from-gray-900 via-gray-900/70 to-transparent pl-5 pointer-events-auto"
				>
					<button
						type="button"
						@click="$refs.chipStrip.scrollBy({ left: 180, behavior: 'smooth' })"
						class="text-gray-300 hover:text-gray-100 transition-colors text-lg leading-none"
						aria-label="Scroll categories right"
					>›</button>
				</div>
			</div>
		</div>

		<!-- Results list (HTMX swap target) -->
		<div id="preset-results">
			@partials.PresetResults(cats, filter)
		</div>

		<!-- Escape hatch -->
		<div class="mt-6 pt-4 border-t border-gray-800 text-center">
			<a href="/skills/new/custom" class="text-indigo-400 text-sm hover:text-indigo-300 transition-colors">
				+ Create a custom skill instead
			</a>
		</div>
	</div>
}

// PresetBrowse renders the full page (direct browser navigation).
templ PresetBrowse(allCats []skills.Category, cats []skills.CategoryWithPresets, filter skills.PresetFilter) {
	@layout.Shell("skills") {
		@PresetBrowseContent(allCats, cats, filter)
	}
}
