package pages

import (
	"github.com/meden/rpgtracker/internal/templates/layout"
	"github.com/meden/rpgtracker/internal/templates/partials"
)

// Error500Content renders the 500 error fragment (for HTMX swaps).
templ Error500Content() {
	@partials.ErrorPartial("Something went wrong", "An unexpected error occurred. Please try again.", "/")
}

// Error500 renders the full 500 error page.
templ Error500() {
	@layout.Shell("") {
		@Error500Content()
	}
}
