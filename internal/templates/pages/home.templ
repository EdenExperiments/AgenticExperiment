package pages

import "github.com/meden/rpgtracker/internal/templates/layout"

templ Home() {
	@layout.Shell("RpgTracker") {
		<div class="max-w-2xl mx-auto py-8">
			<h1 class="text-3xl font-bold text-gray-100">Welcome to RpgTracker</h1>
			<p class="mt-2 text-gray-400">Your gamified skill progression tracker.</p>
		</div>
	}
}
