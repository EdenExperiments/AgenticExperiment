package pages

import (
	"github.com/meden/rpgtracker/internal/templates/layout"
	"github.com/meden/rpgtracker/internal/templates/partials"
)

// Error404Content renders the 404 error fragment (for HTMX swaps).
templ Error404Content() {
	@partials.ErrorPartial("Page not found", "The page you're looking for doesn't exist.", "/")
}

// Error404 renders the full 404 error page.
templ Error404() {
	@layout.Shell("") {
		@Error404Content()
	}
}
